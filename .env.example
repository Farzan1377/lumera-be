# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# Flask / CORS / Auth blocks may exist in your local .env — see repo history or docs.

# ===== Multi-instance: task + run_state in DynamoDB (optional) =====
# Set to enable cross-process reads for TaskManager + simulation run polling (same table name in all API workers).
# Table PK: id (String). Attributes: entity_type (TASK|RUN), payload (JSON string), updated_at
# DYNAMODB_APP_STATE_TABLE_NAME=lumera-app-state
#
# aws dynamodb create-table --table-name lumera-app-state \
#   --attribute-definitions AttributeName=id,AttributeType=S \
#   --key-schema AttributeName=id,KeyType=HASH \
#   --billing-mode PAY_PER_REQUEST --region YOUR_REGION
#
# IAM on the API role: dynamodb:GetItem, PutItem, Scan on that table ARN